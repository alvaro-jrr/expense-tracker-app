generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Currency {
  id        String   @id @default(ulid())
  code      String
  symbol    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  wallets   Wallet[]
}

model User {
  id            String          @id @default(ulid())
  name          String?
  password      String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  // Optional for WebAuthn support
  Authenticator Authenticator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  wallets   Wallet[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// Optional for WebAuthn support
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Wallet {
  id            String        @id @default(ulid())
  userId        String
  currencyId    String
  description   String
  balance       Decimal       @default(0) @db.Decimal(15, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]
  transfersFrom Transfer[]    @relation("FromWallet")
  transfersTo   Transfer[]    @relation("ToWallet")

  user     User     @relation(fields: [userId], references: [id])
  currency Currency @relation(fields: [currencyId], references: [id])
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Category {
  id   String          @id @default(ulid())
  type TransactionType
  name String

  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(ulid())
  categoryId  String
  walletId    String
  amount      Decimal  @db.Decimal(15, 2)
  description String
  date        DateTime @db.Date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  wallet   Wallet   @relation(fields: [walletId], references: [id])
}

model Transfer {
  id           String   @id @default(ulid())
  fromWalletId String
  toWalletId   String
  amount       Decimal  @db.Decimal(15, 2)
  date         DateTime @db.Date
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fromWallet Wallet @relation(name: "FromWallet", fields: [fromWalletId], references: [id])
  toWallet   Wallet @relation(name: "ToWallet", fields: [toWalletId], references: [id])
}
